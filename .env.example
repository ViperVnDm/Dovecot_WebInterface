# Application settings
# Generate SECRET_KEY with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/admin.db

# Session settings
SESSION_EXPIRE_HOURS=24

# Cookie security — set to false only if running without HTTPS (development only)
COOKIE_SECURE=true

# Mail server paths (adjust for your system)
MAIL_LOG_PATH=/var/log/mail.log
MAIL_SPOOL_PATH=/var/mail
POSTFIX_QUEUE_PATH=/var/spool/postfix

# Privileged helper socket
HELPER_SOCKET_PATH=/run/dovecot-webadmin/helper.sock

# SMTP for alert email notifications
# SMTP_FROM must be a real address on your domain (e.g. alerts@yourdomain.com)
# Leaving it empty disables email alerts
SMTP_FROM=alerts@yourdomain.com
SMTP_HOST=localhost
SMTP_PORT=25

# Rate limiting (brute-force protection on /login)
LOGIN_RATE_LIMIT=5/minute

# Log-triage agent (Anthropic)
# Get a key at console.anthropic.com — Claude Pro does NOT grant API access.
# The agent stays disabled until you also flip its enabled flag in the UI.
ANTHROPIC_API_KEY=
LOG_AGENT_MODEL=claude-haiku-4-5-20251001
# Hard cap; agent skips runs once today's usage hits this.
LOG_AGENT_DAILY_COST_CAP_USD=1.0
# Maximum IPs sent to the LLM per run (pre-LLM cap).
LOG_AGENT_MAX_IPS_PER_RUN=50
# Additional log paths read by the privileged helper for the agent.
AUTH_LOG_PATH=/var/log/auth.log
UFW_LOG_PATH=/var/log/ufw.log
